# ── 既有 ────────────────────────────────────────────────
# GitHub API（stars / 專案語言統計用）
GITHUB_TOKEN=

# Google Programmable Search（站內 Google 搜尋用，如有）
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_CX=

# ── 部落格留言（Giscus，選填）─────────────────────────────
# 到 https://giscus.app 設定後取得下列 4 個值；未填則留言區自動隱藏。
# repo 需為 public、已安裝 giscus app、並開啟 Discussions。
NEXT_PUBLIC_GISCUS_REPO=            # 例：YinCheng0106/personal-website
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=        # 例：Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# ── 文章瀏覽數（Upstash Redis，選填）──────────────────────
# 到 https://upstash.com 建立 Redis 後取得；未填則瀏覽數自動隱藏。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
